{
  "@type": "@context",
  "@schema": "http://vascular.ai/schema#",
  "@base": "http://vascular.ai/data/"
}
{
  "@id": "Vessel",
  "@type": "Class",
  "@key": { "@type": "Lexical", "@fields": ["latin_name"] },
  "latin_name": "xsd:string",
  "russian_name": "xsd:string",
  "english_name": { "@type": "Optional", "@class": "xsd:string" },
  "category": {
    "@type": "Enum",
    "@id": "VesselCategory",
    "@values": ["artery", "vein", "lymphatic", "anomalous"]
  },
  "parent_vessel": { "@type": "Optional", "@class": "Vessel" },
  "segments": {
    "@type": "Set",
    "@class": "VesselSegment"
  },
  "topography": {
    "@type": "Set",
    "@class": "TopographicRelation"
  },
  "protocols": {
    "@type": "Set",
    "@class": "TreatmentProtocol"
  },
  "illustrations": {
    "@type": "Optional",
    "@class": "Illustrations"
  },
  "dicom_mask_url": { "@type": "Optional", "@class": "xsd:string" },
  "model_3d_url": { "@type": "Optional", "@class": "xsd:string" }
}
