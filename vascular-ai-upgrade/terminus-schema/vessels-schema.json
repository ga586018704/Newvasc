          "interface": "input",
          "options": {
            "placeholder": "Arteria femoralis communis"
          }
        }
      },
      {
        "field": "russian_name",
        "type": "string",
        "meta": {
          "interface": "input",
          "special": ["translations"]
        }
      },
      {
        "field": "segments",
        "type": "json",
        "meta": {
          "interface": "json",
          "options": {
            "template": [
              {
                "id": "segment_1",
                "name": "Проксимальный сегмент",
                "boundaries": ["T12", "L3"],
                "length_mm": "100-120",
                "diameter_mm": "8-10",
                "variations": []
              }
            ]
          }
        }
      },
      {
        "field": "topography_relations",
        "type": "alias",
        "schema": {
          "foreign_key_column": "vessel_id",
          "foreign_key_table": "topographic_relations"
        },
        "meta": {
          "interface": "list-o2m",
          "special": ["o2m"]
        }
      },
      {
        "field": "illustrations",
        "type": "json",
        "meta": {
          "interface": "file-preview",
          "options": {
            "fields": ["svg_schematic", "photo_real", "dicom_mask", "model_3d"]
          }
        }
      },
      {
        "field": "treatment_protocols",
        "type": "alias",
